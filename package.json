{
  "name": "bun-react-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "jotai": "bun --hot ./jotai/index.html",
    "rtk": "bun --hot ./rtk/index.html",
    "signals": "bun --hot ./signals/index.html",
    "useContext": "bun --hot ./useContext/index.html",
    "useReducer": "bun --hot ./useReducer/index.html",
    "useState": "bun --hot ./useState/index.html",
    "zustand": "bun --hot ./zustand/index.html",
    "build": "bun build ./$0/index.html --outdir=dist --sourcemap --target=bun --minify --define:process.env.NODE_ENV='\"production\"' --env='BUN_PUBLIC_*'",
    "start": "NODE_ENV=production bun ./$0/index.html",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@preact/signals-react": "^3.9.1",
    "@reduxjs/toolkit": "^2.11.2",
    "classnames": "^2.2.6",
    "jotai": "^2.18.1",
    "react": "^19",
    "react-dom": "^19",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.13.1",
    "todomvc-app-css": "^2.0.0",
    "todomvc-common": "^1.0.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "prettier": "^3.8.1"
  },
  "prettier": {
    "arrowParens": "always",
    "bracketSpacing": true,
    "printWidth": 80,
    "singleQuote": false,
    "trailingComma": "none"
  }
}
